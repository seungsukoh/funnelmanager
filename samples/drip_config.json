{
  "field_mapping": {
    "email": ["이메일", "email"],
    "name": ["이름", "name"],
    "event_name": "event_name",
    "followup_url": "followup_url",
    "attendance": "참석여부",
    "marketing_consent": "마케팅동의",
    "unsubscribed": "수신거부"
  },
  "global_excludes": [
    {
      "field": "unsubscribed",
      "operator": "truthy",
      "reason": "수신거부"
    },
    {
      "field": "marketing_consent",
      "operator": "falsy",
      "reason": "마케팅 동의 없음"
    }
  ],
  "steps": [
    {
      "id": "funnel_first_mail",
      "priority": 10,
      "conditions": [
        {
          "field": "campaign_step",
          "operator": "is_empty"
        }
      ],
      "template": "event_followup",
      "set_status": "육성중",
      "add_tags": ["퍼널메일"],
      "next_step": "funnel_second_mail",
      "next_send_after_days": 2
    },
    {
      "id": "funnel_second_mail",
      "priority": 20,
      "conditions": [
        {
          "field": "campaign_step",
          "operator": "equals",
          "value": "funnel_second_mail"
        },
        {
          "field": "lead_tags",
          "operator": "contains",
          "value": "퍼널메일"
        }
      ],
      "template": "event_second_touch",
      "set_status": "관심있음",
      "add_tags": ["추가안내완료"],
      "set_step": "funnel_complete"
    }
  ]
}
